{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@enhancement/types": ["./packages/types/src/index.ts"],
      "@enhancement/bus": ["./packages/bus/src/index.ts"],
      "@enhancement/test-harness": ["./packages/test-harness/src/index.ts"],
      "@enhancement/join-synchronizer": ["./packages/join-synchronizer/src/index.ts"],
      "@enhancement/deferred-queue": ["./packages/deferred-queue/src/index.ts"],
      "@enhancement/config": ["./packages/config/src/index.ts"],
      "@enhancement/store": ["./packages/store/src/index.ts"],
      "@enhancement/screenpipe": ["./packages/screenpipe/src/index.ts"],
      "@enhancement/ai-providers": ["./packages/ai-providers/src/index.ts"],
      "@enhancement/discovery": ["./packages/discovery/src/index.ts"],
      "@enhancement/credentials": ["./packages/credentials/src/index.ts"],
      "@enhancement/plugins": ["./packages/plugins/src/index.ts"],
      "@enhancement/recipe": ["./packages/recipe/src/index.ts"],
      "@enhancement/fabric": ["./packages/fabric/src/index.ts"],
      "@enhancement/cron": ["./packages/cron/src/index.ts"],
      "@enhancement/channel": ["./packages/channel/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
